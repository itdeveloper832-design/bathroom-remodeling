rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Leads collection rules
    match /leads/{leadId} {
      // Allow anyone to create a lead
      allow create: if true;
      
      // Allow reading and managing leads (for admin dashboard)
      // In a production app, you should restrict this to authenticated admins
      allow read, update, delete: if true;
    }

    // Mail collection rules (for Firebase Trigger Email extension)
    match /mail/{mailId} {
      // Allow anyone to trigger an email
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
