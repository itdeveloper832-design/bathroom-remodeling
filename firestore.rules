rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leads collection:
    // - Public can ONLY create (form submissions)
    // - Admin dashboard reads via getDocs (allowed)
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if true;
    }

    // Mail collection (Firebase Trigger Email extension):
    // - Allow create to trigger email notifications
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Block all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
