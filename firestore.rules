rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow anyone to submit a new lead to the 'leads' collection
    match /leads/{leadId} {
      // Users can ONLY create documents. 
      // They CANNOT read, update, or delete existing leads.
      allow create: if request.resource.data.keys().hasAll(['name', 'phone', 'email', 'type', 'createdAt'])
                    && request.resource.data.type in ['quote', 'contact'];
      
      // Admin bypass (assuming you access via Firebase Console or have custom admin claims later)
      allow read, update, delete: if false; 
    }
  }
}
