# ARZ Home Remodeling - cPanel .htaccess Configuration
# Place this file in /home/digitalskills/arzhomeremodeling.com/

DirectoryIndex index.html
ErrorDocument 404 /404.html

# --- BEGIN REDIRECTS ---
